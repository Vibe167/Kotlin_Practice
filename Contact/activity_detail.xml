<!-- res/layout/activity_detail.xml -->
<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top header -->
        <LinearLayout
            android:id="@+id/headerBg"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#4CAF50">

            <!-- Back button -->
            <TextView
                android:id="@+id/tvBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="16dp" />

            <!-- Big circular ImageView -->
            <ImageView
                android:id="@+id/ivDetailAvatar"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:background="@drawable/circle_avatar_clip_large"
                android:clipToOutline="true"
                android:contentDescription="Contact photo" />

            <!-- Name -->
            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Details section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="16dp"/>
            <TextView
                android:id="@+id/tvDetailPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="17sp"
                android:textColor="#1A1A2E"
                android:layout_marginTop="4dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEEEEE" android:layout_marginTop="14dp"/>

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="16dp"/>
            <TextView
                android:id="@+id/tvDetailEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="17sp"
                android:textColor="#1A1A2E"
                android:layout_marginTop="4dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEEEEE" android:layout_marginTop="14dp"/>

            <!-- Birthday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Birthday"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="16dp"/>
            <TextView
                android:id="@+id/tvDetailBirthday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="17sp"
                android:textColor="#1A1A2E"
                android:layout_marginTop="4dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#EEEEEE" android:layout_marginTop="14dp"/>

            <!-- Role -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Role"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="16dp"/>
            <TextView
                android:id="@+id/tvDetailRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="17sp"
                android:textColor="#1A1A2E"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
